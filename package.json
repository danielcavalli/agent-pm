{
  "name": "agent-pm",
  "version": "0.0.4-alpha",
  "description": "File-based project management for AI agent workflows — track epics, stories, and progress across multiple agents",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "pm": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/danielcavalli/agent-pm.git"
  },
  "homepage": "https://github.com/danielcavalli/agent-pm#readme",
  "bugs": {
    "url": "https://github.com/danielcavalli/agent-pm/issues"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js dist/mcp-server.js",
    "pm": "node dist/cli.js",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src"
  },
  "keywords": [
    "project-management",
    "cli",
    "ai-agents"
  ],
  "author": "Dan",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/react": "^19.2.14",
    "chalk": "^5.3.0",
    "clipboardy": "^5.3.1",
    "commander": "^12.0.0",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "js-yaml": "^4.1.0",
    "react": "^19.2.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
